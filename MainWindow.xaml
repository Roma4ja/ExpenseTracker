<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ExpenseTracker.ViewModels"
        Title="Менеджер расходов" Height="500" Width="600">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <StackPanel Margin="20">

        <!-- Поля ввода -->
        <TextBlock Text="Название:"/>
        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="Сумма:" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="Категория:" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Кнопка -->
        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            
            <Button Content="Добавить" 
            Command="{Binding AddCommand}"
            Width="100"/>
            
            <Button Content="Удалить" 
            Command="{Binding DeleteCommand}"
            Width="100" Margin="10,0,0,0"/>

            <Button Content ="Сохранить"
             Command="{Binding SaveCommand}"
             Width="100" Margin="10,0,0,0"/>

            <Button Content = "Загрузить"
             Command="{Binding LoadCommand}"
             Width="100" Margin="10,0,0,0"/>



        </StackPanel>




        <!-- Общая сумма -->
        <TextBlock Text="{Binding TotalExpense, StringFormat='Итого: {0:N2} ₽'}" 
           Margin="0,10,0,0" FontSize="16"/>

        
        <ListView ItemsSource="{Binding Expenses}"
          SelectedItem="{Binding SelectedExpense}"
          Margin="0,10,0,0" Height="250">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название" DisplayMemberBinding="{Binding Title}" Width="150"/>
                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Amount}" Width="100"/>
                    <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding Category}" Width="120"/>
                    <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding Date}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

    </StackPanel>
</Window>